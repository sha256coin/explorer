# S256 RPC Configuration
RPC_USER=your_rpc_username
RPC_PASSWORD=your_secure_rpc_password
RPC_HOST=127.0.0.1
RPC_PORT=25332

# MongoDB Configuration
# Format: mongodb://username:password@localhost:27017/database
MONGODB_URI=mongodb://your_mongo_user:your_mongo_password@localhost:27017/s256explorer
# For MongoDB Atlas (cloud):
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/s256explorer

# Explorer Server Port
PORT=3000

# Node Environment
NODE_ENV=development
